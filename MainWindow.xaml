<Window x:Class="AiAssistanceUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiAssistanceUI"
        Title="Cybersecurity Awareness Chatbot" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#2C3E50">

    <Window.Resources>
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="10,5,50,5"/>
        </Style>

        <Style x:Key="ChatBubbleBot" TargetType="Border">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="50,5,10,5"/>
        </Style>

        <Style x:Key="MessageTextUser" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="MessageTextBot" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#229954" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VoiceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#C0392B" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderBrush="#2980B9" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuizButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9B59B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#8E44AD" 
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#34495E" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           FontFamily="Consolas" 
                           FontSize="8" 
                           Foreground="#27AE60"
                           Text="
    ╔══════════════════════════════════════════════════════════╗
    ║     ██████╗██╗   ██╗██████╗ ███████╗██████╗ ███████╗     ║
    ║    ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗██╔════╝     ║
    ║    ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝███████╗     ║
    ║    ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗╚════██║     ║
    ║    ╚██████╗   ██║   ██████╔╝███████╗██║  ██║███████║     ║
    ║     ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚══════╝     ║
    ║                 Cybersecurity Awareness                  ║
    ╚══════════════════════════════════════════════════════════╝"
                           Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="🤖 Cybersecurity Guardian" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl Grid.Row="1" Margin="5,5,5,5">
            <TabItem Header="💬 Chat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Messages Area -->
                    <ScrollViewer Grid.Row="0" 
                                  x:Name="ChatScrollViewer" 
                                  Background="#F5F6FA"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChatMessagesPanel" 
                                   Orientation="Vertical" 
                                   Margin="10"
                                   VerticalAlignment="Top"/>
                    </ScrollViewer>

                    <!-- Sentiment Indicator -->
                    <Border Grid.Row="1" Background="#ECF0F1" Padding="10" Height="35">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎭 Detected Sentiment: " 
                                      FontSize="12" 
                                      FontWeight="Bold" 
                                      Foreground="#7F8C8D"/>
                            <TextBlock x:Name="SentimentIndicator" 
                                      FontSize="12" 
                                      Foreground="#27AE60"
                                      Text="Neutral"/>
                        </StackPanel>
                    </Border>

                    <!-- Input Area -->
                    <Border Grid.Row="2" Background="White" Padding="10,8" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="UserInputTextBox" 
                                    Grid.Column="0"
                                    Height="40"
                                    FontSize="14"
                                    Padding="10,5"
                                    VerticalContentAlignment="Center"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    TextChanged="UserInputTextBox_TextChanged"
                                    KeyDown="UserInputTextBox_KeyDown">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White" 
                                                BorderBrush="#BDC3C7" 
                                                BorderThickness="1" 
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>

                            <Button x:Name="VoiceInputButton" 
                                   Grid.Column="1"
                                   Style="{StaticResource VoiceButtonStyle}"
                                   Content="🎤 Voice"
                                   Click="VoiceInputButton_Click"/>

                            <Button x:Name="SendButton" 
                                   Grid.Column="2"
                                   Style="{StaticResource SendButtonStyle}"
                                   Content="Send ➤"
                                   Click="SendButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📋 Tasks">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="TaskTitleTextBox" Grid.Row="0" Margin="0,0,0,5" Height="30"
                             Text="Task title"/>
                    <TextBox x:Name="TaskDescriptionTextBox" Grid.Row="1" Margin="0,0,0,5" Height="30"
                             Text="Description"/>
                    <TextBox x:Name="TaskReminderTextBox" Grid.Row="2" Margin="0,0,0,5" Height="30"
                             Text="Reminder (e.g. 'in 3 days')"/>

                    <Button x:Name="AddTaskButton" Grid.Row="3" Content="➕ Add Task" Height="30"
                            HorizontalAlignment="Left" Width="120"
                            Style="{StaticResource TaskButtonStyle}"
                            Click="AddTaskButton_Click"/>

                    <ListBox x:Name="TaskListBox" Grid.Row="4" Margin="0,10,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#555"/>
                                    <TextBlock Text="{Binding Reminder}" Foreground="#888" FontStyle="Italic" FontSize="11"/>
                                    <TextBlock Text="{Binding IsComplete, StringFormat='Status: {0}'}" 
                                               Foreground="{Binding IsComplete, Converter={StaticResource BooleanToBrushConverter}}"/>
                                    <TextBlock Text="{Binding CreatedAt}" Foreground="#AAA" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="5" Orientation="Horizontal">
                        <Button x:Name="MarkCompleteButton" Content="✅ Mark Complete" Width="130" Height="30" Margin="0,0,10,0"
                                Style="{StaticResource TaskButtonStyle}"
                                Click="MarkCompleteButton_Click"/>
                        <Button x:Name="DeleteTaskButton" Content="🗑️ Delete" Width="100" Height="30"
                                Style="{StaticResource TaskButtonStyle}"
                                Click="DeleteTaskButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🧠 Quiz" Height="22" Margin="-2,-2,-2,0" VerticalAlignment="Top">
                <Grid Margin="20">

                    <StackPanel x:Name="QuizStartPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🧠 Test your cybersecurity knowledge!" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" TextAlignment="Center"/>
                        <TextBlock Text="Answer 10+ questions about password safety, phishing, privacy, and more." FontSize="14" Margin="0,0,0,20" TextAlignment="Center" Foreground="#666"/>
                        <Button x:Name="StartQuizButton" Content="🚀 Start Quiz" Width="160" Height="40" 
                                Style="{StaticResource QuizButtonStyle}" Click="StartQuizButton_Click"/>
                    </StackPanel>

                    <Grid x:Name="QuizQuestionPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="QuizScoreText" Grid.Row="0" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                        <TextBlock x:Name="QuizQuestionText" Grid.Row="1" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,15" FontWeight="SemiBold"/>

                        <StackPanel Grid.Row="2" Margin="0,0,0,15">
                            <RadioButton x:Name="OptionARadio" GroupName="QuizOptions" Margin="0,4" FontSize="14"/>
                            <RadioButton x:Name="OptionBRadio" GroupName="QuizOptions" Margin="0,4" FontSize="14"/>
                            <RadioButton x:Name="OptionCRadio" GroupName="QuizOptions" Margin="0,4" FontSize="14"/>
                            <RadioButton x:Name="OptionDRadio" GroupName="QuizOptions" Margin="0,4" FontSize="14"/>
                        </StackPanel>

                        <Button x:Name="SubmitAnswerButton" Grid.Row="3" Content="Submit Answer" Width="140" Height="35"
                                Style="{StaticResource QuizButtonStyle}" HorizontalAlignment="Left" Click="SubmitAnswerButton_Click"/>

                        <TextBlock x:Name="QuizFeedbackText" Grid.Row="4" TextWrapping="Wrap" Margin="0,15,0,15" FontStyle="Italic" FontSize="14"/>

                        <Button x:Name="NextQuestionButton" Grid.Row="5" Content="Next Question ➤" Width="140" Height="35"
                                Style="{StaticResource QuizButtonStyle}" HorizontalAlignment="Left" 
                                Visibility="Collapsed" Click="NextQuestionButton_Click"/>
                    </Grid>

                    <StackPanel x:Name="QuizResultsPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🎉 Quiz Complete!" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" TextAlignment="Center"/>
                        <TextBlock x:Name="QuizFinalScoreText" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" TextAlignment="Center"/>
                        <TextBlock x:Name="QuizFinalMessageText" FontSize="14" Margin="0,0,0,20" TextAlignment="Center" Foreground="#666"/>
                        <Button x:Name="RestartQuizButton" Content="🔄 Play Again" Width="140" Height="36" 
                                Style="{StaticResource QuizButtonStyle}" Click="RestartQuizButton_Click"/>
                    </StackPanel>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>